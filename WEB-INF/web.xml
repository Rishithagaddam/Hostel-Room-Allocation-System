<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Hostel Allocation System</display-name>
    <description>Full Stack Hostel Room Allocation System</description>

    <!-- LoginServlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.hostel.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- WardenServlet -->
    <servlet>
        <servlet-name>WardenServlet</servlet-name>
        <servlet-class>com.hostel.WardenServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WardenServlet</servlet-name>
        <url-pattern>/warden</url-pattern>
    </servlet-mapping>

    <!-- StudentServlet -->
    <servlet>
        <servlet-name>StudentServlet</servlet-name>
        <servlet-class>com.hostel.StudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentServlet</servlet-name>
        <url-pattern>/student</url-pattern>
    </servlet-mapping>

    <!-- AllocationServlet -->
    <servlet>
        <servlet-name>AllocationServlet</servlet-name>
        <servlet-class>com.hostel.AllocationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AllocationServlet</servlet-name>
        <url-pattern>/api/allocate-room</url-pattern>
    </servlet-mapping>

    <!-- DashboardStatsServlet -->
    <servlet>
        <servlet-name>DashboardStatsServlet</servlet-name>
        <servlet-class>com.hostel.DashboardStatsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardStatsServlet</servlet-name>
        <url-pattern>/api/dashboard-stats</url-pattern>
    </servlet-mapping>

    <!-- RegisteredStudentsServlet -->
    <servlet>
        <servlet-name>RegisteredStudentsServlet</servlet-name>
        <servlet-class>com.hostel.RegisteredStudentsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisteredStudentsServlet</servlet-name>
        <url-pattern>/api/registered-students</url-pattern>
    </servlet-mapping>

    <!-- RoomsServlet -->
    <servlet>
        <servlet-name>RoomsServlet</servlet-name>
        <servlet-class>com.hostel.RoomsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RoomsServlet</servlet-name>
        <url-pattern>/api/rooms</url-pattern>
    </servlet-mapping>

    <!-- HostelStructureServlet -->
    <servlet>
        <servlet-name>HostelStructureServlet</servlet-name>
        <servlet-class>com.hostel.HostelStructureServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HostelStructureServlet</servlet-name>
        <url-pattern>/structure</url-pattern>
    </servlet-mapping>

    <!-- AllocatedStudentsServlet -->
    <servlet>
        <servlet-name>AllocatedStudentsServlet</servlet-name>
        <servlet-class>com.hostel.AllocatedStudentsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AllocatedStudentsServlet</servlet-name>
        <url-pattern>/api/allocated-students</url-pattern>
    </servlet-mapping>

    <!-- Session Configuration -->
    <session-config>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <!-- Welcome Files -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>
